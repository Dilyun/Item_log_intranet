VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-anon-key

# Render 봇(Web Service) 주소 — 검은 돈 로그 작성 API
# 예: https://item-log-intranet.onrender.com
VITE_API_URL=http://localhost:3000

# Discord OAuth는 Supabase Dashboard > Authentication > Providers > Discord 에서 설정합니다.
# Redirect URL 예:
# http://localhost:5173
# https://your-app.vercel.app
# Supabase Callback:
# https://your-project-ref.supabase.co/auth/v1/callback
