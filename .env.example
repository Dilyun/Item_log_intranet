# Discord / Render 봇용 (로컬에서는 server.env 또는 .env 사용)
DISCORD_TOKEN=replace-with-your-discord-bot-token
TRADE_LOG_CHANNEL_ID=123456789012345678
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# 프론트엔드(Vercel)에서 검은 돈 로그 API 호출 허용 Origin (쉼표 구분)
# 예: https://devdilyunintranet.vercel.app,http://localhost:5173
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
